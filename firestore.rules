rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profiles
    match /users/{userId} {
      // Allow reading if authenticated
      // Also allow reading employer profiles for public company info (companyLogo, companyDescription)
      // This enables job listings to display company logos/descriptions for all users
      // Note: This makes employer profiles publicly readable, but is necessary for job listings
      allow read: if request.auth != null || 
                     (resource != null && 
                      resource.data != null && 
                      resource.data.role == 'employer');
      allow write: if request.auth.uid == userId;
    }
    
    // Jobs
    match /jobs/{jobId} {
      allow read: if true; // Public read
      allow create: if request.auth != null && request.resource.data.employerId == request.auth.uid;
      allow update, delete: if request.auth.uid == resource.data.employerId;
    }
    
    // Applications
    match /applications/{applicationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth.uid == resource.data.userId || request.auth.uid == resource.data.employerId;
    }
    
    // Quizzes
    match /quizzes/{quizId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
    }
    
    // Spelling Quizzes
    match /spellingQuizzes/{quizId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // Spelling quizzes are immutable once created
    }
    
    // Quiz Results - NEW
    match /quizResults/{resultId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Results cannot be modified
    }
    
    // User Stats - NEW (for badges system)
    match /userStats/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth.uid == userId;
      allow delete: if false; // Stats cannot be deleted
    }
    
    // Earned Badges - NEW
    match /earnedBadges/{badgeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Badges cannot be modified or removed once earned
    }
    
    // Old badges collection (if still used)
    match /badges/{badgeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth.uid == resource.data.userId;
    }
    
    // Chat messages
    match /messages/{messageId} {
      allow read, write: if request.auth != null;
    }
    
    // Chat rooms
    match /chatRooms/{roomId} {
      // Helper function to check if user is a participant
      function isParticipant() {
        return request.auth != null && 
               resource.data.participants != null &&
               resource.data.participants.hasAny([request.auth.uid]);
      }
      
      // Helper function to check if user will be a participant in new room
      function willBeParticipant() {
        return request.auth != null && 
               request.resource.data.participants != null &&
               request.resource.data.participants.hasAny([request.auth.uid]);
      }
      
      // Read: User must be a participant (use array-contains query works with this)
      allow read: if request.auth != null && 
                     resource.data.participants != null &&
                     resource.data.participants.hasAny([request.auth.uid]);
      
      // Create: User must be included in participants array
      allow create: if request.auth != null &&
                     request.resource.data.participants != null &&
                     request.resource.data.participants.hasAny([request.auth.uid]) &&
                     request.resource.data.participants is list &&
                     request.resource.data.participantNames is list &&
                     request.resource.data.participantNames.size() == request.resource.data.participants.size();
      
      // Update: User must be a participant, and can only update specific fields
      allow update: if request.auth != null &&
                     isParticipant() && (
        // Allow updating lastMessage, lastMessageSender, lastMessageAt (when sending messages)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'lastMessageSender', 'lastMessageAt'])) ||
        // Allow updating deletedFor array and deletedAt together (when deleting conversation)
        // Check: deletedFor is being added or updated, and the new value is a list containing current user
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedFor', 'deletedAt']) &&
         request.resource.data.deletedFor is list &&
         request.resource.data.deletedFor.hasAny([request.auth.uid])) ||
        // Allow updating deletedFor array alone (when deleting conversation, backward compatibility)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedFor']) &&
         request.resource.data.deletedFor is list &&
         request.resource.data.deletedFor.hasAny([request.auth.uid])) ||
        // Allow updating deletedFor, deletedAt, lastMessage, lastMessageSender, and lastMessageAt together (when reactivating deleted room)
        // User must be removed from deletedFor (user is no longer in deletedFor list)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedFor', 'deletedAt', 'lastMessage', 'lastMessageSender', 'lastMessageAt']) &&
         request.resource.data.deletedFor is list &&
         !request.resource.data.deletedFor.hasAny([request.auth.uid]) &&
         resource.data.deletedFor.hasAny([request.auth.uid])) ||
        // Allow updating deletedFor, lastMessage, lastMessageSender, and lastMessageAt together (when reactivating deleted room, backward compatibility)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedFor', 'lastMessage', 'lastMessageSender', 'lastMessageAt']) &&
         request.resource.data.deletedFor is list &&
         !request.resource.data.deletedFor.hasAny([request.auth.uid]) &&
         resource.data.deletedFor.hasAny([request.auth.uid])) ||
        // Allow updating participant names or roles if needed
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantNames', 'participantRoles']))
      );
      
      // Delete: Not allowed (use deletedFor array instead)
      allow delete: if false;
    }
    
    // Company reviews
    match /reviews/{reviewId} {
      allow read: if true; // Public read
      allow create: if request.auth != null && 
                    request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
                             request.auth.uid == resource.data.userId;
    }

    // Candidate Reviews (Employers can read all, jobseekers can only read reviews about themselves)
    match /candidateReviews/{reviewId} {
      function isEmployer() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'employer';
      }
      function isJobSeekerViewingOwnReview() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'jobseeker' &&
          resource.data.candidateId == request.auth.uid;
      }
      allow read: if isEmployer() || isJobSeekerViewingOwnReview();
      allow create: if isEmployer() &&
        request.resource.data.candidateId is string &&
        request.resource.data.employerId == request.auth.uid &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;
      allow update: if isEmployer() &&
        resource.data.employerId == request.auth.uid &&
        resource.data.rating is number &&
        resource.data.rating >= 1 &&
        resource.data.rating <= 5;
      allow delete: if isEmployer() && resource.data.employerId == request.auth.uid;
    }

    // Candidate Reviews (Employers can read all, jobseekers can only read reviews about themselves)
    match /candidateReviews/{reviewId} {
      function isEmployer() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'employer';
      }
      function isJobSeeker() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'jobseeker';
      }
      function isJobSeekerViewingOwnReview() {
        return isJobSeeker() && resource.data.candidateId == request.auth.uid;
      }
      allow read: if isEmployer() || isJobSeekerViewingOwnReview();
      allow create: if isEmployer() &&
        request.resource.data.candidateId is string &&
        request.resource.data.employerId == request.auth.uid &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;
      allow update: if isEmployer() &&
        resource.data.employerId == request.auth.uid &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;
      allow delete: if isEmployer() && resource.data.employerId == request.auth.uid;
    }
  }
}

